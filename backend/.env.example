# Database - replace with your local PostgreSQL credentials
DATABASE_URL=postgresql://postgres@localhost:5432/tripcraft

# JWT - generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-this-with-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Unsplash API - get your key at https://unsplash.com/developers
# Required only for fetch_unsplash_quiz_images.py (quiz image pipeline)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# Anthropic API - get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# CORS - comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Redis / RQ - required for background ML photo analysis jobs
REDIS_URL=redis://localhost:6379/0
RQ_ML_QUEUE_NAME=tripcraft-ml
RQ_ML_JOB_TIMEOUT_SECONDS=600
RQ_ML_RESULT_TTL_SECONDS=3600
RQ_ML_FAILURE_TTL_SECONDS=86400
